# Copia este archivo a `.env` en la raíz de regalo-magico (Vite solo lee vars que empiezan por VITE_).

# Catálogo solo local (sin backend):
# VITE_USE_API=false

# Con backend: Vite reenvía /api al backend en el host (ajusta al puerto publicado, p. ej. 8086 si compose mapea 8086:8085).
VITE_USE_API=true
VITE_API_BASE_URL=/api

# Desarrollo local: backend Docker expone 8086→8085 por defecto (docker-compose).
# VITE_DEV_API_PROXY=http://127.0.0.1:8086
#
# Si corres solo `node backend` en el puerto 8085:
# VITE_DEV_API_PROXY=http://127.0.0.1:8085

# Opcional: crear/editar productos desde herramientas (curl) con Bearer ADMIN_TOKEN
# (misma variable en el servicio backend del compose).

# --- Solo docker-compose (no las usa Vite; sí el archivo `.env` que lee Compose) ---
# FRONTEND_PORT=3006
# BACKEND_PORT_HOST=8086
# BACKEND_PORT_INTERNAL=8085
# DB_PORT_HOST=54326
# DB_NAME=regalomagico1
# DB_USER=equipo1
# DB_PASSWORD=equipo1pass
# ADMIN_TOKEN=
